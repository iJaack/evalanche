{
  "name": "evalanche",
  "version": "1.5.3",
  "description": "Multi-EVM agent wallet SDK with onchain identity (ERC-8004), payment rails (x402), cross-chain bridging (Li.Fi + Gas.zip), and perpetual futures (dYdX v4)",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "evalanche-mcp": "./dist/mcp/cli.mjs"
  },
  "files": [
    "dist",
    "skill"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "avalanche",
    "ethereum",
    "base",
    "arbitrum",
    "agent",
    "wallet",
    "erc-8004",
    "x402",
    "bridge",
    "cross-chain",
    "lifi",
    "gas-zip",
    "web3",
    "ai-agent"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@avalabs/avalanchejs": "^5.0.0",
    "@avalabs/core-wallets-sdk": "^3.0.2",
    "@dydxprotocol/v4-client-js": "^3.6.0",
    "big.js": "^7.0.1",
    "ethers": "^6.13.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.1"
  },
  "overrides": {
    "@ledgerhq/cryptoassets": "9.13.0",
    "@hpke/core": "^1.9.0",
    "axios": "^1.13.6",
    "@dydxprotocol/v4-client-js": {
      "axios": "^1.13.6",
      "@osmonauts/lcd": "^1.0.3"
    },
    "@osmonauts/lcd": {
      "axios": "^1.13.6"
    }
  }
}
